# Postgres connection string used by Sequelize.
# Local example: postgres://bloguser:blogpass@localhost:5432/blogdb
DATABASE_URL=

# Secret used to sign JWT access tokens. Use a long random string.
JWT_SECRET=

# S3 bucket where post images are uploaded via pre-signed URLs.
S3_BUCKET=
AWS_REGION=us-east-1

# Optional: override the default port (8080).
PORT=8080
